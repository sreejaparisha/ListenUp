{
  "rewrites": [
    {
      "source": "/",
      "destination": "/pages/index.html"
    },
    {
      "source": "/login",
      "destination": "/pages/login.html"
    },
    {
      "source": "/signup",
      "destination": "/pages/signup.html"
    },
    {
      "source": "/premium",
      "destination": "/pages/premium.html"
    },
    {
      "source": "/artists",
      "destination": "/pages/artists.html"
    },
    {
      "source": "/songs",
      "destination": "/pages/more-songs.html"
    },
    {
      "source": "/(.*)",
      "destination": "/pages/$1"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, immutable"
        }
      ]
    }
  ],
  "env": {
    "NEXT_PUBLIC_APP_NAME": "ListenUp"
  }
}
